# ==========================================================================
# chkp-cpuse-orch .gitignore
# This repo will become PUBLIC. Anything that could leak customer
# infrastructure, credentials, or deployment topology MUST stay untracked.
# When in doubt, add it here. See also .claudeignore.
# ==========================================================================

# --- Secrets & credentials (NEVER commit) --------------------------------
*.key
*.pem
*.pfx
*.p12
*.crt
*.cer
*.der
id_rsa*
id_ecdsa*
id_ed25519*
known_hosts
*.pw
*.pwd
*.secret
*.secrets
secrets.*
credentials.*
.credentials
# ...but the credential-store *source module* is code, not a secret:
!src/chkp_cpuse_orch/credentials.py
*.env
.env
.env.*
!.env.example
vault-password*
*.vault

# --- Customer / site inventory & deployment topology ---------------------
# Real inventories name management servers, gateways, IPs, and SICs.
# Only *.example / *.sample templates are allowed to be tracked.
inventory.y*ml
inventory/*.y*ml
inventories/
hosts.y*ml
sites/
environments/
!*.example.y*ml
!*.sample.y*ml
!example*.y*ml
!sample*.y*ml

# --- CDT artifacts (deployment plans, package repo, results) -------------
# CDT XML plans and CSV target lists embed gateway names/IPs.
cdt_plans/
deployment_plans/
*.cdt.xml
targets*.csv
packages/
repository/
*.tgz
*.tar
*.tar.gz

# --- Runtime output: logs, reports, state --------------------------------
logs/
*.log
run/
runs/
state/
*.state
reports/
out/
output/
artifacts/

# --- Python --------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
env/
ENV/
.python-version

# --- Tooling / test / type caches ----------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.cache/
.hypothesis/

# --- Editors & OS --------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.code-workspace
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- Local overrides -----------------------------------------------------
*.local
*.local.*
local/
scratch/
tmp/

# --- Local-only project memory (host-specific; real infra identifiers) ---
# This note names the internal test host + account; must not enter the public repo.
.claude/memory/test-host-deploy.md

# --- Local-only dev-host bootstrap doc (OneDrive-synced, never committed) --
# Sensitive infra identifiers for the test host; carry it across machines via
# OneDrive/manual copy, never git. (Also matched by *.local.* below.)
DEV-HOST.local.md

# --- Docker runtime data (bind-mounted into the container) ---------------
/data/
