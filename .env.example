# Example environment file — SAFE TO COMMIT (placeholders only).
# Copy to `.env` (git-ignored) OR export these in your shell / load from a secrets
# store; never commit the real .env. These are service-level settings — per-host
# SSH credentials are NOT set here: add them in the web UI, encrypted at rest.

# Master key for the encrypted credential store. Held in memory only; nothing
# readable lands on the data volume. Without it, credential/patching endpoints
# return 503 and everything else still works. NEVER commit the real value.
# CHKP_CPUSE_MASTER_KEY=changeme

# Optional: path to a config file (else built-in defaults are used).
# CHKP_CPUSE_CONFIG=./config.yaml

# Optional: days to keep an uploaded package before it is auto-deleted, unless
# the operator pins it ("Keep") in the web UI. 0 disables auto-expiry entirely.
# Overrides package_retention_days from the config file. Default: 30.
# CHKP_CPUSE_PACKAGE_RETENTION_DAYS=30

# --- Web UI authentication (LDAP / Active Directory) ------------------------
# Auth is OPTIONAL: leave these unset to run without a login (safe only on a
# trusted network) — but credential storage cannot be enabled while auth is off.
# Auth turns ON when BOTH CHKP_CPUSE_LDAP_URL and CHKP_CPUSE_LDAP_REQUIRED_GROUP
# are set; a partial config fails startup rather than silently running open.
#
# Directory URL(s), comma-separated for failover. Use ldaps:// for TLS.
# CHKP_CPUSE_LDAP_URL=ldaps://dc1.corp.example.com:636,ldaps://dc2.corp.example.com:636
#
# DN of the group whose members may access the tool (direct memberOf check).
# CHKP_CPUSE_LDAP_REQUIRED_GROUP=CN=CPUSE-Admins,OU=Groups,DC=corp,DC=example,DC=com
#
# Service account used to look up the user's DN (search-then-bind). Omit BOTH of
# these if you instead use CHKP_CPUSE_LDAP_USER_DN_TEMPLATE for a direct bind.
# CHKP_CPUSE_LDAP_BIND_DN=CN=svc-cpuse,OU=Service Accounts,DC=corp,DC=example,DC=com
# CHKP_CPUSE_LDAP_BIND_PASSWORD=changeme
# Or read the bind password from a file (docker secret); the inline var above
# wins if both are set.
# CHKP_CPUSE_LDAP_BIND_PASSWORD_FILE=/run/secrets/ldap_bind_password
#
# Base DN to search for users (required with a service account).
# CHKP_CPUSE_LDAP_USER_BASE_DN=OU=Users,DC=corp,DC=example,DC=com
# User search filter; {username} is substituted (and escaped). Default is AD's
# sAMAccountName; use e.g. (uid={username}) for OpenLDAP/posix directories.
# CHKP_CPUSE_LDAP_USER_FILTER=(sAMAccountName={username})
#
# Alternative to a service account: bind directly as the user via a DN template.
# {username} is substituted. Example uses an AD UPN.
# CHKP_CPUSE_LDAP_USER_DN_TEMPLATE={username}@corp.example.com
#
# Attribute holding the user's group DNs. Default: memberOf.
# CHKP_CPUSE_LDAP_MEMBER_OF_ATTR=memberOf
#
# TLS: use StartTLS on a plain ldap:// connection, verify the server cert, and
# point at a CA bundle if the directory uses a private CA.
# CHKP_CPUSE_LDAP_START_TLS=false
# CHKP_CPUSE_LDAP_TLS_VERIFY=true
# CHKP_CPUSE_LDAP_CA_CERT=/etc/ssl/certs/corp-ca.pem
#
# Session: idle minutes before auto-logout (also clears tab-cached credentials),
# and whether the session cookie carries the Secure flag (set false only for
# plain-HTTP local dev). Defaults: 30, true.
# CHKP_CPUSE_SESSION_IDLE_MINUTES=30
# CHKP_CPUSE_SESSION_COOKIE_SECURE=true
