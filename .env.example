# Example environment file — SAFE TO COMMIT (placeholders only).
# Copy to `.env` (git-ignored) OR export these in your shell / load from a secrets
# store. Secrets are resolved by name at runtime; never commit the real .env.

# One variable per host, referenced by `secret_ref` in the inventory.
CHKP_MGMT01_SSH_PASSWORD=changeme
CHKP_FW01_SSH_PASSWORD=changeme
CHKP_CLUSTERA_M1_SSH_PASSWORD=changeme
CHKP_CLUSTERA_M2_SSH_PASSWORD=changeme

# Optional: path to a config file (else built-in defaults are used).
# CHKP_CPUSE_CONFIG=./config.yaml
